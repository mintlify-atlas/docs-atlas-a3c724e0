{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Dotfiles",
  "theme": "aspen",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/ombratteng/dotfiles"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ombratteng/dotfiles"
    }
  },
  "navigation": {
