            "pages": [
              "config/shell",
              "config/git",
              "config/tmux",
              "config/vim"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "tools/overview",
              "tools/atuin",
              "tools/bat",
              "tools/eza",
              "tools/powerlevel10k",
              "tools/oh-my-zsh"
            ]
          },
          {
            "group": "Scripts",
            "pages": [
              "scripts/bootstrap",
              "scripts/installation",
              "scripts/upgrade"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Shell",
            "pages": [
              "reference/aliases",
              "reference/functions",
              "reference/environment"
